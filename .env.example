# ============================================
# Relay — environment configuration
# Copy this to .env and fill in real values
# ============================================

# General
NODE_ENV=development
LOG_LEVEL=debug

# API
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000

# Worker
WORKER_CONCURRENCY=5
# Comma-separated hostnames that bypass SSRF protection (e.g. for local dev: localhost,127.0.0.1,::1)
SSRF_ALLOWED_TARGETS=

# Database (Postgres)
DATABASE_URL=postgres://relay:relay@localhost:5432/relay
# Connection pool sizing (postgres.js has no native min — prewarmPool() is available)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Webhook delivery (defaults, can be overridden per-endpoint)
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_RETRY_SCHEDULE=60,300,1800,7200,43200,86400
WEBHOOK_USER_AGENT=Relay/0.1.0

# Signing
SIGNING_ALGORITHM=sha256

# Circuit breaker
# CIRCUIT_BREAKER_THRESHOLD=10
# CIRCUIT_BREAKER_COOLDOWN_MS=300000

# Data retention (messages older than this are purged periodically)
# DATA_RETENTION_DAYS=90
# CLEANUP_INTERVAL_MS=3600000

# Auth
JWT_SECRET=change-me-to-a-secret-at-least-32-characters-long

# Rate limiting (per endpoint, per second)
RATE_LIMIT_PER_SECOND=100
RATE_LIMIT_BURST=200
